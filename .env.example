# ---- Spotify ----
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback

# ---- X (Twitter) ----
# Create an app at https://developer.x.com/portal/dashboard with OAuth 2.0 PKCE
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/callback

# ---- xAI Grok (default LLM analyzer) ----
# Get a key at https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-4-fast

# ---- OAuth fallback (optional) ----
# Used when you cannot run a local loopback server. Deploy vercel/index.html
# and put its URL here. Leave blank to skip the fallback.
DJX_VERCEL_FALLBACK_URL=

# ---- Cache / data dirs ----
DJX_CACHE_DIR=~/.djx/cache
DJX_TOKENS_PATH=~/.djx/tokens.json
DJX_RUNS_DIR=~/.djx/runs

# ---- Tuning ----
DJX_MAX_ARTISTS=20
DJX_PLAYLIST_TRACK_COUNT=30
DJX_REQUEST_TIMEOUT=30
